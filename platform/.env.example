# TrustOS platform — local development defaults.
# Copy to .env (per service or repo root). Env vars always win over .env files.
# Naming: each service prefixes its vars (referral-service => REFERRAL_).

# ── referral-service ────────────────────────────────────────────────────────
REFERRAL_ENVIRONMENT=local
REFERRAL_REGION=ap-south-1
REFERRAL_DATABASE_URL=postgresql+asyncpg://trustos:trustos@localhost:5432/referral
REFERRAL_DB_POOL_SIZE=10
REFERRAL_REDIS_URL=redis://localhost:6379/0
REFERRAL_KAFKA_BOOTSTRAP=localhost:9092
REFERRAL_TEMPORAL_ADDRESS=localhost:7233
REFERRAL_TEMPORAL_NAMESPACE=referral
REFERRAL_CURSOR_SECRET=dev-only-cursor-secret-change-me
# Dev stand-in for the trust-service gRPC band lookup (see infrastructure/gateways/trust.py)
REFERRAL_TRUST_BAND_DEFAULT=silver
# Leave empty to disable OTLP export in local dev
REFERRAL_OTLP_ENDPOINT=
